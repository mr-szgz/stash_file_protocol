{
  "manifest_version": 3,
  "name": "Stash Protocol Bridge",
  "version": "0.0.1",
  "description": "Intercepts stash:// links and forwards to the OS protocol handler.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Stash Protocol"
  }
}
